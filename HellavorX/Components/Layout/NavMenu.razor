﻿@using Microsoft.AspNetCore.Components.Authorization

<nav class="bg-gray-900 sticky top-0 z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="text-white text-2xl font-bold hover:text-blue-500 transition">HellavorX</a>
        
        <div class="flex items-center gap-8">
            <AuthorizeView>
                <Authorized>
                    <form method="get" action="/search" class="relative">
                        <input type="text" name="Query"
                            class="w-64 px-4 py-2 bg-gray-800 text-white border border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder-gray-400 text-sm"
                            placeholder="Search users or posts..." />
                        <svg class="w-4 h-4 absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </form>
                    <a href="/" class="text-white hover:text-blue-500 transition">Feed</a>
                    <a href="/explore" class="text-white hover:text-blue-500 transition">Explore</a>
                    <a href="/profile" class="text-white hover:text-blue-500 transition">Profile</a>
                    <a href="/logout" class="text-white hover:text-blue-500 transition">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="text-white hover:text-blue-500 transition">Login</a>
                    <a href="/signup" class="text-white hover:text-blue-500 transition">Sign Up</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

