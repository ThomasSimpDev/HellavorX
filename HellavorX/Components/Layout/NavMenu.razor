@using Microsoft.AspNetCore.Components.Authorization

<nav class="bg-gray-900 sticky top-0 z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="text-white text-2xl font-bold hover:text-blue-500 transition">HellavorX</a>
        
        <div class="flex gap-8">
            <AuthorizeView>
                <Authorized>
                    <a href="/" class="text-white hover:text-blue-500 transition">Feed</a>
                    <a href="/profile" class="text-white hover:text-blue-500 transition">Profile</a>
                    <a href="/logout" class="text-white hover:text-blue-500 transition">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="text-white hover:text-blue-500 transition">Login</a>
                    <a href="/signup" class="text-white hover:text-blue-500 transition">Sign Up</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

