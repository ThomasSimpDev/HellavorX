@using HellavorX.Models
@rendermode InteractiveServer

<div class="@(IsReply ? "ml-6 mt-3 pl-4 border-l-2 border-gray-200" : "pb-4 border-b border-gray-100 last:border-0")">
    <div class="flex items-start gap-3">
        <img src="@(Comment.User.ProfilePictureUrl ?? "/favicon.png")" class="w-8 h-8 rounded-full object-cover ring-2 ring-gray-100 flex-shrink-0" />
        <div class="flex-1">
            <div class="bg-gray-50 rounded-lg p-3">
                <div class="flex items-center gap-2 mb-1">
                    <span class="font-semibold text-sm text-gray-900">@Comment.User.Name</span>
                    <span class="text-xs text-gray-500">@@@Comment.User.UserName</span>
                    <span class="text-xs text-gray-400">· @Comment.CreatedAt.ToString("MMM dd, HH:mm")</span>
                    @if (Comment.UserId == currentUserId)
                    {
                        <button class="text-xs text-blue-600 hover:underline ml-auto" @onclick="BeginEdit">Edit</button>
                        <button class="text-xs text-red-600 hover:underline" @onclick="ConfirmDelete">Delete</button>
                    }
                </div>
                @if (isEditing)
                {
                    <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="space-y-2 mt-2">
                        <InputTextArea @bind-Value="editModel.Content" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 resize-none text-sm" rows="2" />
                        <div class="flex gap-2">
                            <button type="submit" class="px-3 py-1 bg-green-600 text-white text-xs rounded hover:bg-green-700">Save</button>
                            <button type="button" class="px-3 py-1 bg-gray-200 text-gray-700 text-xs rounded hover:bg-gray-300" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <p class="text-sm text-gray-800 whitespace-pre-wrap">@Comment.Content</p>
                }
            </div>
            
            @if (Comment.MediaFiles.Any())
            {
                <div class="space-y-2 mt-2">
                    @foreach (var media in Comment.MediaFiles)
                    {
                        @if (media.Type == MediaType.Image)
                        {
                            <img src="@media.Url" class="max-w-sm rounded-lg" />
                        }
                        else if (media.Type == MediaType.Audio)
                        {
                            <audio controls src="@media.Url" class="max-w-sm"></audio>
                        }
                        else if (media.Type == MediaType.Video)
                        {
                            <video controls src="@media.Url" class="max-w-sm rounded-lg"></video>
                        }
                        else if (media.Type == MediaType.File)
                        {
                            <a href="@media.Url" download class="inline-block text-blue-600 hover:underline text-sm">
                                @media.FileName
                            </a>
                        }
                    }
                </div>
            }
            
            <button class="text-sm text-gray-600 hover:text-blue-600 font-medium mt-2 transition" @onclick="() => OnReplyClick?.Invoke(Comment)">Reply</button>

            @if (Comment.Replies.Any())
            {
                <div class="mt-3 space-y-3">
                    @foreach (var reply in Comment.Replies)
                    {
                        <CommentThread Comment="reply" PostId="PostId" OnReplySubmit="OnReplySubmit" OnReplyClick="OnReplyClick" IsReply="true" />
                    }
                </div>
            }
        </div>
    </div>
</div>


