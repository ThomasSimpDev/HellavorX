@page "/post/{id:int}"
@using HellavorX.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Post - HellavorX</PageTitle>

@if (post != null)
{
    <div class="max-w-3xl mx-auto space-y-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="p-6">
                <div class="flex items-start gap-3 mb-4">
                    <img src="@(post.User.ProfilePictureUrl ?? "/favicon.png")" class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-100" />
                    <div class="flex-1">
                        <a href="/profile/@post.User.UserName" class="font-semibold text-gray-900 hover:text-blue-600 transition">@post.User.Name</a>
                        <div class="flex items-center gap-2 text-sm text-gray-500">
                            <span>@@@post.User.UserName</span>
                            <span>·</span>
                            <span>@post.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                    </div>
                    @if (post.UserId == currentUserId)
                    {
                        <div class="flex gap-2">
                            <button class="text-sm text-blue-600 hover:underline" @onclick="() => BeginEdit()">Edit</button>
                            <button class="text-sm text-red-600 hover:underline" @onclick="ConfirmDelete">Delete</button>
                        </div>
                    }
                </div>
                
                @if (isEditing)
                {
                    <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="space-y-4">
                        <InputTextArea @bind-Value="editModel.Content" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none text-lg" rows="4" />
                        <div class="flex gap-2">
                            <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">Save</button>
                            <button type="button" class="px-6 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <p class="text-gray-800 mb-4 whitespace-pre-wrap leading-relaxed text-lg">@post.Content</p>
                }

                @if (post.MediaFiles.Any())
                {
                    <div class="space-y-3">
                        @foreach (var media in post.MediaFiles)
                        {
                            @if (media.Type == MediaType.Image)
                            {
                                <img src="@media.Url" class="w-full rounded-lg" />
                            }
                            else if (media.Type == MediaType.Audio)
                            {
                                <audio controls src="@media.Url" class="w-full"></audio>
                            }
                            else if (media.Type == MediaType.Video)
                            {
                                <video controls src="@media.Url" class="w-full rounded-lg"></video>
                            }
                            else if (media.Type == MediaType.File)
                            {
                                <a href="@media.Url" download class="inline-block text-blue-600 hover:underline">
                                    @media.FileName
                                </a>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h4 class="text-xl font-semibold mb-4">Comments</h4>
            
            <div class="mb-6">
                @if (replyingTo != null)
                {
                    <div class="mb-2 text-sm text-gray-600 flex items-center gap-2">
                        <span>Replying to <span class="font-semibold">@@@replyingTo.User.UserName</span></span>
                        <button class="text-red-500 hover:text-red-700" @onclick="CancelReply">✕</button>
                    </div>
                }
                <EditForm Model="newComment" OnValidSubmit="() => AddComment(replyingTo?.Id)" class="space-y-3">
                    <InputTextArea @bind-Value="newComment.Content" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" placeholder="Write a comment..." rows="3" />
                    <div class="flex items-center gap-2">
                        <label class="flex items-center gap-2 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 rounded-lg cursor-pointer transition text-sm">
                            <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                            </svg>
                            <span>Attach</span>
                            <InputFile OnChange="HandleCommentFileSelection" multiple class="hidden" accept="*/*" />
                        </label>
                        @if (selectedCommentFiles.Any())
                        {
                            <span class="text-sm text-gray-500">(@selectedCommentFiles.Count file(s))</span>
                        }
                        <button type="submit" class="ml-auto px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition disabled:opacity-50" disabled="@isCommenting">Comment</button>
                    </div>
                    @if (selectedCommentFiles.Any())
                    {
                        <div class="space-y-1">
                            @foreach (var file in selectedCommentFiles)
                            {
                                <div class="flex items-center justify-between bg-gray-50 px-3 py-1 rounded-lg">
                                    <span class="truncate text-sm">@file.Name</span>
                                    <button type="button" class="text-red-500 hover:text-red-700" @onclick="() => selectedCommentFiles.Remove(file)">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </EditForm>
            </div>

            <div class="space-y-4">
                @foreach (var comment in post.Comments.Where(c => c.ParentCommentId == null))
                {
                    <CommentThread Comment="comment" PostId="Id" OnReplySubmit="LoadPost" OnReplyClick="HandleReplyClick" />
                }
            </div>
        </div>
    </div>
}


