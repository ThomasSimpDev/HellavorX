@page "/signup"
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Sign Up - HellavorX</PageTitle>

<div class="max-w-md mx-auto mt-10">
    <h2 class="text-3xl font-bold mb-6">Create Account</h2>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">@errorMessage</div>
    }

    <form method="post" action="/api/auth/signup" class="space-y-4">
        <input name="__RequestVerificationToken" type="hidden" value="@GetAntiforgeryToken()" />
        <div>
            <label class="block mb-2 font-medium">Name</label>
            <input name="name" class="w-full px-4 py-2 border rounded" required />
        </div>

        <div>
            <label class="block mb-2 font-medium">Username</label>
            <input name="username" class="w-full px-4 py-2 border rounded" required />
        </div>

        <div>
            <label class="block mb-2 font-medium">Email</label>
            <input name="email" type="email" class="w-full px-4 py-2 border rounded" required />
        </div>

        <div>
            <label class="block mb-2 font-medium">Password</label>
            <input name="password" type="password" class="w-full px-4 py-2 border rounded" required minlength="6" />
        </div>

        <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
            Sign Up
        </button>
    </form>

    <p class="mt-4">Already have an account? <a href="/login" class="text-blue-600 hover:underline">Login</a></p>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] protected IHttpContextAccessor? HttpContextAccessor { get; set; }

    private string? errorMessage;

    protected override void OnInitialized()
    {
        // Check for error query parameter
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var error))
        {
            errorMessage = error.ToString();
        }
    }

    private string? GetAntiforgeryToken()
    {
        return HttpContextAccessor?.HttpContext?.Request.Cookies["XSRF-TOKEN"];
    }
}

