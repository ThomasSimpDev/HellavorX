@page "/"
@using HellavorX.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Feed - HellavorX</PageTitle>

<div class="max-w-3xl mx-auto space-y-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-xl font-semibold mb-4">Create Post</h3>
        <EditForm Model="newPost" OnValidSubmit="CreatePost" class="space-y-4">
            <InputTextArea @bind-Value="newPost.Content" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" placeholder="What's on your mind?" rows="4" />
            
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <div class="flex items-center gap-2">
                    <label class="flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg cursor-pointer transition">
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <span class="text-sm font-medium text-gray-700">Add File</span>
                        <InputFile OnChange="HandleFileSelection" multiple class="hidden" accept="*/*" />
                    </label>
                    @if (selectedFiles.Any())
                    {
                        <span class="text-sm text-gray-500 ml-2">(@selectedFiles.Count file(s) selected)</span>
                    }
                </div>

                <button type="submit" class="mt-2 sm:mt-0 px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition disabled:opacity-50" disabled="@isPosting">
                    @(isPosting ? "Posting..." : "Post")
                </button>
            </div>

            @if (selectedFiles.Any())
            {
                <div class="mt-3 space-y-1">
                    @foreach (var file in selectedFiles)
                    {
                        <div class="flex items-center justify-between bg-gray-50 px-3 py-1 rounded-lg">
                            <span class="truncate text-sm">@file.Name</span>
                            <button type="button" class="text-red-500 hover:text-red-700" @onclick="() => RemoveFile(file)">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </EditForm>
    </div>

    @foreach (var post in posts)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition relative">
            <div class="p-6">
                <div class="flex items-start gap-3 mb-4">
                    <img src="@(post.User.ProfilePictureUrl ?? "/favicon.png")" class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-100" />
                    <div class="flex-1">
                        <a href="/profile/@post.User.UserName" class="font-semibold text-gray-900 hover:text-blue-600 transition">@post.User.Name</a>
                        <div class="flex items-center gap-2 text-sm text-gray-500">
                            <span>@@@post.User.UserName</span>
                            <span>·</span>
                            <span>@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    @if (post.UserId == currentUserId)
                    {
                        <div class="flex gap-2 ml-4">
                            <button class="text-sm text-blue-600 hover:underline" @onclick="() => StartEdit(post)">Edit</button>
                            <button class="text-sm text-red-600 hover:underline" @onclick="() => DeletePost(post.Id)">Delete</button>
                        </div>
                    }
                </div>

                @if (editPostId == post.Id)
                {
                    <EditForm Model="editModel" OnValidSubmit="() => SaveEdit(post.Id)" class="space-y-4">
                        <InputTextArea @bind-Value="editModel.Content" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" rows="3" />
                        <div class="flex gap-2">
                            <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">Save</button>
                            <button type="button" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <p class="text-gray-800 mb-4 whitespace-pre-wrap leading-relaxed">@post.Content</p>
                }

                @if (post.MediaFiles.Any())
                {
                    <div class="space-y-3 mb-4">
                        @foreach (var media in post.MediaFiles)
                        {
                            @if (media.Type == MediaType.Image)
                            {
                                <img src="@media.Url" class="w-full rounded-lg" />
                            }
                            else if (media.Type == MediaType.Audio)
                            {
                                <audio controls src="@media.Url" class="w-full"></audio>
                            }
                            else if (media.Type == MediaType.Video)
                            {
                                <video controls src="@media.Url" class="w-full rounded-lg"></video>
                            }
                            else if (media.Type == MediaType.File)
                            {
                                <a href="@media.Url" download class="inline-block text-blue-600 hover:underline">
                                    @media.FileName
                                </a>
                            }
                        }
                    </div>
                }
            </div>

            <div class="border-t border-gray-100 px-6 py-3 bg-gray-50">
                <a href="/post/@post.Id" class="inline-flex items-center gap-2 text-gray-600 hover:text-blue-600 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span class="font-medium">@post.Comments.Count Comments</span>
                </a>
            </div>
        </div>
    }
</div>


