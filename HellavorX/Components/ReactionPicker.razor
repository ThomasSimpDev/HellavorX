@using HellavorX.Models
@using System.Collections.Generic

<div class="relative inline-flex" @onmouseenter="OpenPopup" @onmouseleave="ClosePopup">
    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition text-gray-600 group" @onclick="QuickLike">
        @if (UserReaction.HasValue)
        {
            <i class="@GetReactionIconClass(UserReaction.Value) text-lg leading-none"></i>
            <span class="font-medium text-sm @GetReactionColorClass(UserReaction.Value)">@GetReactionLabel(UserReaction.Value)</span>
        }
        else
        {
            <i class="far fa-thumbs-up text-lg @(IsReacted ? "text-blue-500" : "text-gray-500 group-hover:text-blue-600")"></i>
            <span class="font-medium text-sm">Like</span>
        }
        @if (TotalCount > 0)
        {
            <span class="text-xs text-gray-500 ml-0.5">@TotalCount</span>
        }
    </button>

    @if (showPopup)
    {
        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-white shadow-xl rounded-full px-2 py-1.5 z-[9999] border border-gray-200 flex items-center gap-0.5 pointer-events-auto animate-fade-in-up">
            @foreach (var reaction in ReactionOptions)
            {
                <button class="flex flex-col items-center justify-center p-1.5 hover:bg-gray-100 rounded-full transition-transform hover:scale-110 min-w-[40px]" @onclick="() => SelectReaction(reaction.Type)" title="@reaction.Label">
                    <span class="text-2xl leading-none">@reaction.Emoji</span>
                    <span class="text-[10px] text-gray-500 mt-0.5 font-medium">@reaction.Count</span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? PostId { get; set; }
    [Parameter] public int? CommentId { get; set; }
    [Parameter] public Dictionary<ReactionType, int>? ReactionCounts { get; set; }
    [Parameter] public EventCallback<ReactionType> OnReaction { get; set; }
    [Parameter] public ReactionType? UserReaction { get; set; }

    private bool IsReacted => UserReaction.HasValue;
    private bool showPopup = false;

    private record ReactionOption(ReactionType Type, string Emoji, string Label, int Count);

    private List<ReactionOption> ReactionOptions => new()
    {
        new(ReactionType.Like, "👍", "Like", ReactionCounts?.GetValueOrDefault(ReactionType.Like, 0) ?? 0),
        new(ReactionType.Love, "❤️", "Love", ReactionCounts?.GetValueOrDefault(ReactionType.Love, 0) ?? 0),
        new(ReactionType.Haha, "😂", "Haha", ReactionCounts?.GetValueOrDefault(ReactionType.Haha, 0) ?? 0),
        new(ReactionType.Wow, "😮", "Wow", ReactionCounts?.GetValueOrDefault(ReactionType.Wow, 0) ?? 0),
        new(ReactionType.Sad, "😢", "Sad", ReactionCounts?.GetValueOrDefault(ReactionType.Sad, 0) ?? 0),
        new(ReactionType.Angry, "😠", "Angry", ReactionCounts?.GetValueOrDefault(ReactionType.Angry, 0) ?? 0),
    };

    private static string GetReactionIconClass(ReactionType type) => type switch
    {
        ReactionType.Like => "fas fa-thumbs-up text-blue-600",
        ReactionType.Love => "fas fa-heart text-red-500",
        ReactionType.Haha => "fas fa-face-laugh-squint text-yellow-500",
        ReactionType.Wow => "fas fa-face-surprise text-yellow-500",
        ReactionType.Sad => "fas fa-face-sad-tear text-yellow-600",
        ReactionType.Angry => "fas fa-face-angry text-orange-600",
        _ => "fas fa-thumbs-up text-blue-600"
    };

    private static string GetReactionLabel(ReactionType type) => type switch
    {
        ReactionType.Like => "Like",
        ReactionType.Love => "Love",
        ReactionType.Haha => "Haha",
        ReactionType.Wow => "Wow",
        ReactionType.Sad => "Sad",
        ReactionType.Angry => "Angry",
        _ => "Like"
    };

    private static string GetReactionColorClass(ReactionType type) => type switch
    {
        ReactionType.Like => "text-blue-600",
        ReactionType.Love => "text-red-500",
        ReactionType.Haha => "text-yellow-500",
        ReactionType.Wow => "text-yellow-500",
        ReactionType.Sad => "text-yellow-600",
        ReactionType.Angry => "text-orange-600",
        _ => "text-blue-600"
    };

    private async Task QuickLike()
    {
        await SelectReaction(ReactionType.Like);
    }

    private System.Timers.Timer? closeTimer;

    private void OpenPopup()
    {
        closeTimer?.Stop();
        closeTimer?.Dispose();
        closeTimer = null;
        showPopup = true;
    }

    private void ClosePopup()
    {
        closeTimer = new System.Timers.Timer(150);
        closeTimer.Elapsed += (s, e) =>
        {
            InvokeAsync(() =>
            {
                showPopup = false;
                StateHasChanged();
            });
            closeTimer?.Dispose();
            closeTimer = null;
        };
        closeTimer.AutoReset = false;
        closeTimer.Start();
    }

    private async Task SelectReaction(ReactionType type)
    {
        showPopup = false;
        await OnReaction.InvokeAsync(type);
    }

    private int TotalCount => ReactionCounts?.Values.Sum() ?? 0;
}

